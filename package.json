{
  "name": "@ctrllearning/pinia-orm-root",
  "private": true,
  "scripts": {
    "release": "node scripts/release.mjs",
    "cleanup": "rimraf 'packages/**/node_modules' 'playground/node_modules' 'node_modules'",
    "size": "pnpm --filter './packages/**' size",
    "build": "pnpm --filter './packages/**' build",
    "build:ci": "pnpm --filter './packages/{pinia-orm,normalizr,axios}' build",
    "build:stub": "pnpm --filter './packages/**' build --stub",
    "build:prepare": "pnpm --filter './packages/**' dev:prepare",
    "sponsor": "sponsorkit",
    "build:pinia-orm": "lerna run build --scope pinia-orm",
    "play": "lerna run play",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "pnpm --filter './packages/**' lint",
    "lint:fix": "pnpm --filter './packages/**' lint:fix",
    "test": "pnpm --filter './packages/**' test",
    "test:coverage": "pnpm --filter './packages/**' coverage",
    "test:types": "tsc --build ./tsconfig.json",
    "test:dts": "lerna run test:dts"
  },
  "devDependencies": {
    "@lerna-lite/cli": "^3.12.3",
    "@lerna-lite/run": "^3.12.3",
    "@types/lodash.kebabcase": "^4.1.9",
    "@types/node": "^22.19.17",
    "chalk": "^4.1.2",
    "changelogen": "^0.5.7",
    "conventional-changelog-cli": "^5.0.0",
    "enquirer": "^2.4.1",
    "execa": "^9.6.1",
    "expect": "^29.7.0",
    "globby": "^14.1.0",
    "lint-staged": "^15.5.2",
    "lodash.kebabcase": "^4.1.1",
    "minimist": "^1.2.8",
    "oxfmt": "^0.47.0",
    "p-series": "^3.0.0",
    "pascalcase": "^2.0.0",
    "rimraf": "^6.1.3",
    "semver": "^7.7.4",
    "sponsorkit": "^0.14.7",
    "typescript": "^5.9.3",
    "yorkie": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "@vue/composition-api": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "lint-staged": {
    "*": "oxfmt --no-error-on-unmatched-pattern"
  },
  "packageManager": "pnpm@9.4.0",
  "pnpm": {
    "packageExtensions": {
      "@vue/composition-api": {
        "peerDependencies": {
          "vue": "*"
        }
      }
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "vue": "3"
      }
    },
    "overrides": {
      "nanoid": "3.3.4"
    }
  },
  "gitHooks": {
    "commit-msg": "node scripts/verifyCommit.js"
  }
}
