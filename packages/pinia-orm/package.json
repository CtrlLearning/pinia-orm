{
  "name": "@ctrllearning/pinia-orm",
  "version": "3.5.0",
  "description": "The Pinia plugin to enable Object-Relational Mapping access to the Pinia Store.",
  "keywords": [
    "orm",
    "pinia",
    "pinia-orm",
    "pinia-plugin",
    "vue"
  ],
  "homepage": "https://github.com/CtrlLearning/pinia-orm#readme",
  "bugs": {
    "url": "https://github.com/CtrlLearning/pinia-orm/issues"
  },
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CtrlLearning/pinia-orm.git"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "dist/index.d.ts",
  "unpkg": "dist/index.mjs",
  "jsdelivr": "dist/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.mjs"
    },
    "./dist/*": {
      "types": "./dist/*.d.ts",
      "require": "./dist/*.cjs",
      "import": "./dist/*.mjs"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "require": "./dist/*.cjs",
      "import": "./dist/*.mjs"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "unbuild",
    "coverage": "vitest --run --coverage",
    "size": "size-limit",
    "lint": "oxlint",
    "test:ui": "vitest --ui --api 9527",
    "test:watch": "vitest --watch",
    "test": "vitest --run"
  },
  "dependencies": {
    "@ctrllearning/pinia-orm-normalizr": "workspace:*"
  },
  "devDependencies": {
    "@pinia/testing": "^0.1.7",
    "@size-limit/preset-small-lib": "^11.2.0",
    "@types/node": "^22.19.17",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "@vue/test-utils": "^2.4.10",
    "c8": "^10.1.3",
    "core-js": "^3.49.0",
    "happy-dom": "^16.8.1",
    "mkdist": "^2.4.1",
    "nanoid": "3.3.4",
    "pinia": "^3.0.4",
    "size-limit": "^11.2.0",
    "std-env": "^3.10.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "unbuild": "^3.6.1",
    "uuid": "^10.0.0",
    "vite": "^8.0.10",
    "vitest": "^3.2.4",
    "vue": "^3.5.33"
  },
  "peerDependencies": {
    "pinia": "^3.0.0",
    "vue": "^3.4.31"
  },
  "size-limit": [
    {
      "path": "dist/index.mjs",
      "limit": "16 kB"
    },
    {
      "path": "dist/decorators.mjs",
      "limit": "1 kB"
    },
    {
      "path": "dist/casts.mjs",
      "limit": "1 kB"
    },
    {
      "path": "dist/helpers.mjs",
      "limit": "1 kB"
    }
  ],
  "volta": {
    "node": "22.12.0"
  }
}
