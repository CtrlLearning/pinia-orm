{
  "name": "@ctrllearning/pinia-orm-normalizr",
  "version": "3.2.0",
  "description": "Normalizes JSON according to schema for Redux and Flux applications",
  "keywords": [
    "api",
    "flux",
    "json",
    "normalize",
    "redux"
  ],
  "homepage": "https://github.com/CtrlLearning/pinia-orm",
  "bugs": {
    "url": "https://github.com/CtrlLearning/pinia-orm/issues"
  },
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/CtrlLearning/pinia-orm.git"
  },
  "files": [
    "dist/",
    "index.d.ts",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "index.d.ts",
  "unpkg": "dist/index.mjs",
  "jsdelivr": "dist/index.mjs",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.mjs"
    },
    "./*": "./*"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "unbuild",
    "size": "size-limit",
    "flow": "flow",
    "flow:ci": "flow check",
    "lint": "oxlint"
  },
  "devDependencies": {
    "@size-limit/preset-small-lib": "^11.2.0",
    "immutable": "^5.1.5",
    "oxlint": "^1.62.0",
    "size-limit": "^11.2.0",
    "typescript": "^5.9.3",
    "unbuild": "^3.6.1"
  },
  "size-limit": [
    {
      "path": "dist/index.mjs",
      "limit": "2 kB"
    }
  ]
}
