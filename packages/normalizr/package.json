{
  "name": "@pinia-orm/normalizr",
  "description": "Normalizes JSON according to schema for Redux and Flux applications",
  "keywords": [
    "api",
    "flux",
    "json",
    "normalize",
    "redux"
  ],
  "homepage": "https://github.com/CodeDredd/pinia-orm",
  "bugs": {
    "url": "https://github.com/CodeDredd/pinia-orm/issues"
  },
  "license": "MIT",
  "author": "Paul Armstrong",
  "contributors": [
    "Dan Abramov",
    "Gregor Becker"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/CodeDredd/pinia-orm.git"
  },
  "funding": "https://github.com/sponsors/codedredd",
  "files": [
    "dist/",
    "index.d.ts",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "index.d.ts",
  "unpkg": "dist/index.mjs",
  "jsdelivr": "dist/index.mjs",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.mjs"
    },
    "./*": "./*"
  },
  "scripts": {
    "build": "unbuild",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s --commit-path . -l @pinia-orm/normalizr -r 1",
    "size": "size-limit",
    "flow": "flow",
    "flow:ci": "flow check",
    "lint": "oxlint",
    "lint2": "eslint . --cache",
    "lint:fix": "eslint . --cache --fix"
  },
  "devDependencies": {
    "@size-limit/preset-small-lib": "^11.2.0",
    "immutable": "^5.1.5",
    "oxlint": "^1.62.0",
    "size-limit": "^11.2.0",
    "typescript": "^5.9.3",
    "unbuild": "^3.6.1"
  },
  "size-limit": [
    {
      "path": "dist/index.mjs",
      "limit": "2 kB"
    }
  ]
}
