{
  "name": "@pinia-orm/axios",
  "description": "Axios plugin for pinia-orm",
  "keywords": [
    "api",
    "axios",
    "pinia-orm"
  ],
  "homepage": "https://github.com/CodeDredd/pinia-orm",
  "bugs": {
    "url": "https://github.com/CodeDredd/pinia-orm/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Gregor Becker",
    "email": "gregor@codedredd.de"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/CodeDredd/pinia-orm.git"
  },
  "funding": "https://github.com/sponsors/codedredd",
  "files": [
    "dist/",
    "index.d.ts",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "unpkg": "dist/index.mjs",
  "jsdelivr": "dist/index.mjs",
  "exports": {
    ".": {
      "require": "./dist/index.cjs",
      "import": "./dist/index.mjs"
    },
    "./*": "./*"
  },
  "scripts": {
    "build": "unbuild",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s --commit-path . -l @pinia-orm/axios -r 1",
    "size": "size-limit",
    "lint": "eslint . --cache",
    "lint:fix": "eslint . --cache --fix",
    "test:ui": "vitest --ui --api 9527",
    "test:watch": "vitest --watch",
    "test": "vitest --run"
  },
  "devDependencies": {
    "@size-limit/preset-small-lib": "^11.2.0",
    "@vitest/coverage-v8": "^3.2.4",
    "axios": "^1.15.2",
    "axios-mock-adapter": "^2.1.0",
    "oxlint": "^1.62.0",
    "pinia": "^2.3.1",
    "pinia-orm": "workspace:*",
    "size-limit": "^11.2.0",
    "typescript": "^5.9.3",
    "unbuild": "^3.6.1",
    "vitest": "^3.2.4",
    "vue": "^3.5.33"
  },
  "peerDependencies": {
    "axios": ">=1.7.7",
    "pinia": ">=2.1.7",
    "pinia-orm": ">=1.9.1"
  },
  "size-limit": [
    {
      "path": "dist/index.mjs",
      "limit": "2 kB"
    }
  ]
}
